          ]
        },
        {
          "name": "body",
          "type": "text",
          "multiple": false,
          "values": [
            "Ride the rattling Tram 28 across the old districts, queue for a warm pastel de nata in Belém, and lose an hour in the National Tile Museum admiring centuries of azulejos."
          ]
        },
