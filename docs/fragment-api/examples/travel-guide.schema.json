{
  "type": "object",
  "title": "Travel Guide",
  "$defs": {
    "Location": {
      "type": "object",
      "title": "Location",
      "required": ["city", "country"],
      "properties": {
        "city": { "type": "string", "title": "City", "minLength": 1 },
        "country": { "type": "string", "title": "Country", "minLength": 1 },
        "neighborhood": { "type": "string", "title": "Neighborhood" }
      }
    },
    "Section": {
      "type": "object",
      "title": "Section",
      "required": ["heading"],
      "properties": {
        "heading": { "type": "string", "title": "Heading", "minLength": 1 },
        "body": { "type": "string", "title": "Body" },
        "order": { "type": "integer", "title": "Order", "minimum": 1 }
      }
    },
    "Highlight": {
      "type": "object",
      "title": "Highlight",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "title": "Name", "minLength": 1 },
        "description": { "type": "string", "title": "Description" },
        "mustSee": { "type": "boolean", "title": "Must See", "default": false }
      }
    },
    "SocialLinks": {
      "type": "object",
      "title": "Social Links",
      "properties": {
        "twitter": { "type": "string", "title": "Twitter" },
        "website": { "type": "string", "title": "Website" }
      }
    },
    "Author": {
      "type": "object",
      "title": "Author",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "title": "Name", "minLength": 1 },
        "bio": { "type": "string", "title": "Bio", "maxLength": 500 },
        "social": { "$ref": "#/$defs/SocialLinks" }
      }
    }
  },
  "required": ["title", "destination", "author", "sections"],
  "properties": {
    "title": { "type": "string", "title": "Title", "minLength": 1, "maxLength": 120 },
    "slug": { "type": "string", "title": "Slug", "pattern": "^[a-z0-9-]+$" },
    "subtitle": { "type": "string", "title": "Subtitle", "maxLength": 200 },
    "season": { "type": "string", "title": "Best Season", "enum": ["spring", "summer", "autumn", "winter"], "default": "spring" },
    "budgetLevel": { "type": "string", "title": "Budget Level", "enum": ["budget", "midrange", "luxury"], "default": "midrange" },
    "recommendedDays": { "type": "integer", "title": "Recommended Days", "minimum": 1, "maximum": 30, "default": 2 },
    "averageRating": { "type": "number", "title": "Average Rating", "minimum": 0, "maximum": 5 },
    "estimatedCostUsd": { "type": "number", "title": "Estimated Cost (USD)", "minimum": 0 },
    "familyFriendly": { "type": "boolean", "title": "Family Friendly", "default": false },
    "visaRequired": { "type": "boolean", "title": "Visa Required" },
    "tags": { "type": "array", "title": "Tags", "minItems": 1, "maxItems": 10, "items": { "type": "string", "title": "Tag" } },
    "languagesSpoken": { "type": "array", "title": "Languages Spoken", "items": { "type": "string", "title": "Language" } },
    "travelStyles": { "type": "array", "title": "Travel Styles", "items": { "type": "string", "title": "Travel Style", "enum": ["solo", "couple", "family", "business"] } },
    "destination": { "$ref": "#/$defs/Location" },
    "author": { "$ref": "#/$defs/Author" },
    "sections": { "type": "array", "title": "Sections", "minItems": 1, "items": { "$ref": "#/$defs/Section" } },
    "highlights": { "type": "array", "title": "Highlights", "items": { "$ref": "#/$defs/Highlight" } }
  }
}
